# Token da API Hugging Face (obrigatório para IA)
# Obtenha em: https://huggingface.co/settings/tokens (permissão: Inference Providers)
HF_TOKEN=
# ou
HUGGINGFACE_TOKEN=

# Modelo opcional (padrão: meta-llama/Llama-3.1-8B-Instruct:cheapest)
# HF_CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct:cheapest

# Seu nome para assinatura das respostas (quando Gmail não conectado)
# USER_NAME=João Silva

# Gmail OAuth (veja GMAIL_SETUP.md)
# API_BASE_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:3000
# GOOGLE_CREDENTIALS_PATH=./credentials.json

# PostgreSQL (use docker-compose up -d para subir o banco)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/email_classifier

# Desabilitar job agendado (opcional, para desenvolvimento)
# DISABLE_JOB_SCHEDULER=1
