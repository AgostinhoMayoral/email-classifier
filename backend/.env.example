# Token da API Hugging Face (opcional - sem token usa classificação baseada em regras)
# Obtenha em: https://huggingface.co/settings/tokens
HF_TOKEN=
# ou
HUGGINGFACE_TOKEN=

# Gmail OAuth (veja GMAIL_SETUP.md)
# API_BASE_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:3000
# GOOGLE_CREDENTIALS_PATH=./credentials.json

# PostgreSQL (use docker-compose up -d para subir o banco)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/email_classifier

# Desabilitar job agendado (opcional, para desenvolvimento)
# DISABLE_JOB_SCHEDULER=1
